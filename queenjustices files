-- QUEENJUSTICE REALM DATABASE

CREATE TABLE IF NOT EXISTS sponsors (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  github_username TEXT,
  github_id TEXT,
  action TEXT,
  sponsor_type TEXT DEFAULT 'GitHub Sponsor',
  website TEXT DEFAULT 'https://sites.google.com/view/queenjusticemusic/home?authuser=0',
  vip_status BOOLEAN DEFAULT true,
  created_at TIMESTAMP DEFAULT NOW()
);


CREATE TABLE IF NOT EXISTS fans (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  username TEXT,
  email TEXT UNIQUE,
  avatar_url TEXT,
  membership TEXT DEFAULT 'Fan',
  created_at TIMESTAMP DEFAULT NOW()
);


CREATE TABLE IF NOT EXISTS songs (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  title TEXT NOT NULL,
  release_date DATE,
  streaming_link TEXT,
  created_at TIMESTAMP DEFAULT NOW()
);


CREATE TABLE IF NOT EXISTS events (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  event_name TEXT,
  event_date DATE,
  location TEXT,
  created_at TIMESTAMP DEFAULT NOW()
);


CREATE TABLE IF NOT EXISTS merch (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  item_name TEXT,
  price NUMERIC,
  image_url TEXT,
  store_link TEXT,
  created_at TIMESTAMP DEFAULT NOW()
);


CREATE TABLE IF NOT EXISTS community_posts (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  fan_id UUID REFERENCES fans(id),
  message TEXT,
  created_at TIMESTAMP DEFAULT NOW()
);


